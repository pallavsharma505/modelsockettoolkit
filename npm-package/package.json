{
  "name": "@pallavsharma505/modelsockettoolkit",
  "version": "0.1.1",
  "description": "MST (Model Socket Toolkit) — lightweight bi-directional RPC & PubSub feeds over a single WebSocket",
  "author": "pallavsharma505",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": ["dist"],
  "keywords": [
    "websocket",
    "rpc",
    "pubsub",
    "feeds",
    "realtime",
    "bi-directional",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pallavsharma505/modelsockettoolkit.git"
  },
  "bugs": {
    "url": "https://github.com/pallavsharma505/modelsockettoolkit/issues"
  },
  "homepage": "https://github.com/pallavsharma505/modelsockettoolkit#readme",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "tsx --test src/__tests__/**/*.test.ts"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0"
  }
}
